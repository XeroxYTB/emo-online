# MongoDB Atlas (production) ou local
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=emo

# Production : false | Dev local : true
EMO_DEV_MODE=false
EMO_SERVE_FRONTEND=true

# URLs publiques (sans slash final)
# Monolithe Render : même URL pour les deux
EMO_PUBLIC_BACKEND_URL=https://votre-app.onrender.com
EMO_FRONTEND_URL=https://votre-app.onrender.com
CORS_ORIGINS=https://votre-app.onrender.com

# Google OAuth — redirect = {EMO_PUBLIC_BACKEND_URL}/api/auth/google/callback
# Pour comptes connectés (Gmail/Drive) ajouter aussi :
#   {EMO_PUBLIC_BACKEND_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# GitHub OAuth — comptes connectés (redirect = {EMO_PUBLIC_BACKEND_URL}/api/oauth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# LLM — au moins Groq + HF_TOKEN OU OpenRouter pour le tier gratuit
# Obtenir les clés : scripts\setup-llm-keys.ps1  |  Vérifier : python scripts\check-llm-keys.py
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=          # https://openrouter.ai/keys (modèles :free)
DEEPSEEK_API_KEY=            # https://platform.deepseek.com/api_keys
HF_TOKEN=                    # https://huggingface.co/settings/tokens (sync Space + router HF)
HUGGINGFACE_API_KEY=         # alias optionnel de HF_TOKEN
EMERGENT_LLM_KEY=

# Stripe
STRIPE_API_KEY=
STRIPE_BASIC_LINK=
STRIPE_PREMIUM_LINK=
STRIPE_ULTRA_LINK=
STRIPE_PAYMENT_LINK=
STRIPE_SUBSCRIPTION_LINK=

LICENSE_PRICE_EUR=15.00
LICENSE_INTERVAL=month
SUBSCRIPTION_PERIOD_DAYS=31
EMO_USE_SALES_LLM_KEYS=true

# Clés produit vente (lifetime illimité) — format: tier:CLE,tier:CLE
# Générer: python scripts/generate-product-key.py --tier ultra --count 5
EMO_PRODUCT_KEYS=

# Pool LLM dédié vente (prioritaire si EMO_USE_SALES_LLM_KEYS=true)
SALES_OPENAI_API_KEY=
SALES_ANTHROPIC_API_KEY=
SALES_GEMINI_API_KEY=
SALES_GROQ_API_KEY=
SALES_OPENROUTER_API_KEY=
SALES_DEEPSEEK_API_KEY=
SALES_HF_TOKEN=

# Fly.io (deploy: scripts/deploy-fly.ps1)
FLY_API_TOKEN=
